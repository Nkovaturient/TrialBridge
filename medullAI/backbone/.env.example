# Payment gate for POST /match and POST /batch_match_parsed.
# standard = no payment required (default, recommended for enterprise).
# x402     = require x402 USDC micropayment per request.
PAYMENT_MODE=standard

# Wallet that owns TrialRegistry and signs logMatch txs
PRIVATE_KEY=0x...

# Server secret for HMAC-SHA256(patient_id) → bytes32 on-chain (never commit real value)
PATIENT_HASH_SECRET=use-a-long-random-string-in-production

# TrialRegistry deployed on Base Sepolia
TRIAL_REGISTRY_CONTRACT_ADDRESS=0x40cAD144A2Dc503FdFFcbc84aBBeb0007924fc08

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org

# FastAPI agent server (Phase 1)
AGENT_API_URL=http://localhost:8100

# Express backbone port
PORT=4020

# --- x402 only (when PAYMENT_MODE=x402) ---
# PAY_TO_ADDRESS=0x...
# FACILITATOR_URL=https://facilitator.xpay.sh
# X402_NETWORK="eip155:84532"
